# LLM Provider: "claude" | "openai" | "local"
LLM_PROVIDER=claude

# API Keys (never commit real keys)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Phi-3-mini model path (for "local" LLM provider)
PHI3_MODEL_PATH=./models/phi3-mini-q4.gguf

# Database
DB_PATH=./data/smart_baggage.db
DB_ENCRYPTION_KEY=

# Authentication (set AUTH_API_KEY to enable, AUTH_DISABLED=true to bypass in dev)
AUTH_API_KEY=
AUTH_DISABLED=true

# Rate limiting
RATE_LIMIT_STORAGE=memory://

# Weather API (Open-Meteo requires no key)
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1
GEOCODING_BASE_URL=https://geocoding-api.open-meteo.com/v1

# YOLO model paths
YOLOV8_ONNX_PATH=./models/yolov8n-travel.onnx
YOLOV8_PT_PATH=./models/yolov8n-travel.pt
CLIP_MODEL_ID=openai/clip-vit-base-patch32

# Airline policies
AIRLINE_POLICIES_DIR=./airline_policies

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true